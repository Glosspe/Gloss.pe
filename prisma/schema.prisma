generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Modelo para el acceso de administradores al panel
model WebUsuarioAdmin {
  id        String   @id @default(uuid())
  usuario   String   @unique
  password  String
  nombre    String
  rol       String   @default("ADMIN")
  createdAt DateTime @default(now())

  @@map("web_usuarios_admin")
}

// Modelo para asociar imágenes y descripciones enriquecidas a los artículos del ERP
model WebProductoImagen {
  id                    String   @id @default(uuid())
  codart                String   @unique // Código del artículo en Navasoft ERP (prd0101.codi)
  imagenes              String   @db.Text // JSON string — puede contener data URIs Base64 o URLs
  descripcionEnriquecida String?  @db.Text // Descripción enriquecida para el e-commerce
  destacado             Boolean  @default(false)
  visible               Boolean  @default(true) // Controla si el producto se muestra en la web
  fechaActualizacion    DateTime @updatedAt

  @@map("web_producto_imagenes")
}

// Modelo para controlar la visibilidad y orden de categorías en la web
model WebCategoriaConfig {
  id        String  @id @default(uuid())
  categoria String  @unique  // "Capilar", "Facial", "Cosmeticos", "Corporal"
  visible   Boolean @default(true)
  orden     Int     @default(0)

  @@map("web_categorias_config")
}

// Modelo de respaldo para guardar las cotizaciones/pedidos de la web
model WebPedido {
  id                String   @id @default(uuid())
  nroPedido         String   @unique // Nro de pedido autogenerado, ej: GLOSS-1001
  clienteNombre     String
  clienteTelefono   String   // Celular / WhatsApp
  clienteDocumento  String   // DNI o RUC
  direccion         String
  coordenadas       String?  // Coordenadas "lat,lng" de Google Maps
  productos         String   // JSON string con el array de productos del carrito
  total             Decimal  @db.Decimal(18, 4)
  voucherUrl        String?  // Ruta o URL de la imagen del comprobante
  estado            String   @default("PENDIENTE") // PENDIENTE, PAGADO, CANCELADO
  fechaCreacion     DateTime @default(now())
  nroCotizacionErp  String?  // Número de cotización devuelto por Navasoft al sincronizar

  @@map("web_pedidos")
}

// Modelo para controlar qué sedes/almacenes están habilitados para calcular el stock en la web
model WebAlmacenConfig {
  id        String   @id @default(uuid())
  codalm    String   @unique // Código del almacén en Navasoft ERP (ej: "01", "02", "03", "04", "05", "06")
  nomalm    String   // Nombre descriptivo de la sede
  visible   Boolean  @default(true) // Controla si se suma el stock de este almacén
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("web_almacenes_config")
}

