generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Modelo para el acceso de administradores al panel
model WebUsuarioAdmin {
  id        String   @id @default(uuid())
  usuario   String   @unique
  password  String
  nombre    String
  rol       String   @default("ADMIN")
  createdAt DateTime @default(now())

  @@map("web_usuarios_admin")
}

// Modelo para asociar imágenes y descripciones enriquecidas a los artículos del ERP
model WebProductoImagen {
  id                    String   @id @default(uuid())
  codart                String   @unique // Código del artículo en Navasoft ERP (prd0101.codi)
  imagenes              String   @db.Text // JSON string — puede contener data URIs Base64 o URLs
  descripcionEnriquecida String?  @db.Text // Descripción enriquecida para el e-commerce
  destacado             Boolean  @default(false)
  visible               Boolean  @default(true) // Controla si el producto se muestra en la web
  precio                Decimal  @default(0) @db.Decimal(18, 4) // Precio transaccional del ERP
  stock                 Float    @default(0) // Stock consolidado del ERP
  nombre                String?  // Nombre del producto del ERP
  marca                 String?  // Marca del ERP
  categoria             String?  // Subfamilia o categoría del ERP
  hasEquivalents        Boolean  @default(false) // Indica si tiene productos equivalentes/alternativos en el ERP
  equivalentes          String   @db.Text @default("[]") // Códigos equivalentes en formato JSON array ["0505-xxx", ...]
  sincronizadoEn        DateTime? // Última fecha de sincronización por lote
  fechaActualizacion    DateTime @updatedAt

  @@map("web_producto_imagenes")
}

// Modelo para controlar la visibilidad y orden de categorías en la web
model WebCategoriaConfig {
  id        String  @id @default(uuid())
  categoria String  @unique  // "Capilar", "Facial", "Cosmeticos", "Corporal"
  visible   Boolean @default(true)
  orden     Int     @default(0)

  @@map("web_categorias_config")
}

// Modelo de respaldo para guardar las cotizaciones/pedidos de la web
model WebPedido {
  id                String   @id @default(uuid())
  nroPedido         String   @unique // Nro de pedido autogenerado, ej: GLOSS-1001
  clienteNombre     String
  clienteTelefono   String   // Celular / WhatsApp
  clienteDocumento  String   // DNI o RUC
  direccion         String
  coordenadas       String?  // Coordenadas "lat,lng" de Google Maps
  productos         String   // JSON string con el array de productos del carrito
  total             Decimal  @db.Decimal(18, 4)
  voucherUrl        String?  // Ruta o URL de la imagen del comprobante
  estado            String   @default("PENDIENTE") // PENDIENTE, PAGADO, CANCELADO
  fechaCreacion     DateTime @default(now())
  nroCotizacionErp  String?  // Número de cotización devuelto por Navasoft al sincronizar

  @@map("web_pedidos")
}

// Modelo para controlar qué sedes/almacenes están habilitados para calcular el stock en la web
model WebAlmacenConfig {
  id        String   @id @default(uuid())
  codalm    String   @unique // Código del almacén en Navasoft ERP (ej: "01", "02", "03", "04", "05", "06")
  nomalm    String   // Nombre descriptivo de la sede
  visible   Boolean  @default(true) // Controla si se suma el stock de este almacén
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("web_almacenes_config")
}

// Modelo para configuraciones globales del e-commerce
model WebGlobalConfig {
  id                 String   @id @default(uuid())
  clave              String   @unique // Ej: "LOW_STOCK_THRESHOLD", "ERP_CROSS_SELLING_ACTIVE", "REPLENISHMENT_DAYS"
  valor              String   // Valor guardado como texto/JSON
  fechaActualizacion DateTime @updatedAt

  @@map("web_global_config")
}

// Modelo para atajos y búsquedas sugeridas en caliente en el buscador
model WebSearchShortcut {
  id        String   @id @default(uuid())
  texto     String   @unique // El texto sugerido (ej: "L'Oréal", "Uñas", "Tratamiento")
  tipo      String   // "BRAND", "CATEGORY", "QUERY"
  enlace    String   // Parámetro de búsqueda (ej: "?brand=L'OREAL" o "?category=10-01")
  orden     Int      @default(0)
  visible   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("web_search_shortcuts")
}

// Modelo para etiquetas de preocupación/necesidad y sus asociaciones de productos
model WebProductTag {
  id        String   @id @default(uuid())
  etiqueta  String   @unique // Ej: "#AntiFrizz", "#ControlCaida", "#Brillo", "#CabelloSeco"
  visible   Boolean  @default(true)
  orden     Int      @default(0)
  productos String   @db.Text // JSON array con los códigos de artículo asociados (ej: '["0505-010288", "0505-010337"]')
  createdAt DateTime @default(now())

  @@map("web_product_tags")
}

// Modelo para asociaciones de venta cruzada (sugeridos) manuales del administrador
model WebProductCrossSell {
  id        String   @id @default(uuid())
  codart    String   @unique // Código del artículo origen
  productos String   @db.Text // JSON array con los códigos de artículos sugeridos manualmente
  createdAt DateTime @default(now())

  @@map("web_product_cross_sells")
}

